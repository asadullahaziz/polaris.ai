# Polaris AI — single .env for the whole compose project (implementation_plan §1).
# Copy to `.env` and fill secrets. `.env` is gitignored; this template is committed.

# ---- Django ----
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# ---- Postgres (PostGIS) ----
POSTGRES_DB=polaris
POSTGRES_USER=polaris
POSTGRES_PASSWORD=polaris
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis (Channels layer + presence) ----
REDIS_URL=redis://redis:6379/0

# ---- LangGraph checkpointer pool (separate connection from the ORM) ----
# Defaults to the POSTGRES_* DB when unset.
# CHECKPOINTER_DB_URL=postgresql://polaris:polaris@postgres:5432/polaris
CHECKPOINTER_POOL_MAX_SIZE=10

# ---- CORS / CSRF (SPA on :3000, same-site with :8000 -> SameSite=Lax works) ----
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- MinIO / S3 (object storage; inert in P0) ----
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=polaris-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---- Inngest (dev server in compose) ----
INNGEST_APP_ID=polaris
INNGEST_IS_PRODUCTION=false
INNGEST_DEV=1
INNGEST_BASE_URL=http://inngest:8288

# ---- LLM provider (provider-agnostic; #5 deferred — not called in P0) ----
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-REPLACE_ME
# ANTHROPIC_API_KEY=
# POLARIS_MODEL_WORKHORSE=anthropic/claude-sonnet-4.6
# POLARIS_MODEL_ESCALATION=anthropic/claude-opus-4.8
# POLARIS_MODEL_BULK=anthropic/claude-haiku-4.5

# ---- Demo login (dev only; created idempotently on boot) ----
DEMO_USER=demo
DEMO_PASSWORD=demo12345
DEMO_EMAIL=demo@polaris.local

# ---- Frontend (public; baked into the browser bundle) ----
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_WS_BASE=ws://localhost:8000
