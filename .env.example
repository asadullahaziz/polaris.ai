# ---- Django ----
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# ---- Postgres (PostGIS) ----
POSTGRES_DB=polaris
POSTGRES_USER=polaris
POSTGRES_PASSWORD=polaris
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis (Channels layer + presence) ----
REDIS_URL=redis://redis:6379/0

# ---- LangGraph checkpointer pool (separate connection from the ORM) ----
# Defaults to the POSTGRES_* DB when unset.
# CHECKPOINTER_DB_URL=postgresql://polaris:polaris@postgres:5432/polaris
CHECKPOINTER_POOL_MAX_SIZE=10

# ---- CORS / CSRF (SPA on :3000, same-site with :8000 -> SameSite=Lax works) ----
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Email (hand-rolled verify / password-reset tokens) ----
# Without SENDGRID_API_KEY, dev prints emails to the console (fresh clone works).
# Tests use the locmem backend automatically.
# SENDGRID_API_KEY=SG.replace_me
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=Polaris AI <no-reply@polaris.local>
# SPA base for verification/reset links (/verify?token=… , /reset?token=…)
FRONTEND_BASE_URL=http://localhost:3000

# ---- Inngest (dev server in compose) ----
INNGEST_APP_ID=polaris
INNGEST_IS_PRODUCTION=false
INNGEST_DEV=1
INNGEST_BASE_URL=http://inngest:8288

# ---- LLM provider (provider-agnostic; #5 deferred — not called in P0) ----
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-REPLACE_ME
# ANTHROPIC_API_KEY=
# POLARIS_MODEL_WORKHORSE=anthropic/claude-sonnet-4.6
# POLARIS_MODEL_ESCALATION=anthropic/claude-opus-4.8
# POLARIS_MODEL_BULK=anthropic/claude-haiku-4.5

# ---- Langfuse (Cloud) — prompt management + tracing (optional; off when unset) ----
# Prompts fall back to the code constants when unset — fully offline, nothing breaks.
# LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
# LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME
# LANGFUSE_BASE_URL=https://cloud.langfuse.com   # EU region; US = https://us.cloud.langfuse.com
# LANGFUSE_ENABLED=true             # defaults to true iff both keys are set
# LANGFUSE_PROMPT_LABEL=production  # set "latest" to iterate on prompts live
# LANGFUSE_PROMPT_CACHE_TTL=60      # seconds; 0 = refetch every call (demo editing)
# LANGFUSE_SAMPLE_RATE=1.0          # read directly by the SDK

# ---- Demo login (dev only; email-login, created idempotently on boot) ----
DEMO_EMAIL=demo@polaris.local
DEMO_PASSWORD=demo12345

# ---- Frontend (public; baked into the browser bundle) ----
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_WS_BASE=ws://localhost:8000

# ---- Application Settings ----
RESPONDER_GRACE_SECONDS=0